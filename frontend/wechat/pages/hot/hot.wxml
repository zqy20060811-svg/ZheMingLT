<view class="hot-page {{isDarkMode ? 'dark-mode' : ''}}">
  <!-- 时间筛选 -->
  <view class="time-filter">
    <view
      wx:for="{{timeFilters}}"
      wx:key="value"
      class="filter-btn {{currentFilter === item.value ? 'active' : ''}}"
      data-filter="{{item.value}}"
      bindtap="switchFilter"
    >
      {{item.label}}
    </view>
  </view>

  <!-- 热门列表 -->
  <view class="hot-list">
    <view wx:if="{{loading}}" class="loading-state">
      <view class="spinner"></view>
      <text>加载中...</text>
    </view>

    <view wx:elif="{{hotPosts.length > 0}}" class="posts-list">
      <view
        wx:for="{{hotPosts}}"
        wx:key="id"
        wx:for-index="index"
        class="hot-item"
        data-id="{{item.id}}"
        bindtap="goToPost"
      >
        <view class="rank-badge {{index < 3 ? 'top' : ''}}">
          {{index + 1}}
        </view>
        <view class="item-content">
          <text class="item-title">{{item.title}}</text>
          <view class="item-meta">
            <text class="author">{{item.authorName}}</text>
            <text class="divider">·</text>
            <text class="category">{{item.categoryName}}</text>
          </view>
          <view class="item-stats">
            <text class="heat">
              <text class="icon">🔥</text>
              {{item.heat}}°
            </text>
            <text>👁 {{item.viewCount || 0}}</text>
            <text>❤ {{item.likeCount || 0}}</text>
            <text>💬 {{item.commentCount || 0}}</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <text class="icon">📭</text>
      <text>暂无热门帖子</text>
    </view>
  </view>
</view>
