<view class="profile-page {{isDarkMode ? 'dark-mode' : ''}}">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="card-bg"></view>
    <view class="user-info">
      <image class="user-avatar" src="{{user.avatar || defaultAvatar}}" mode="aspectFill" />
      <view class="user-details">
        <text class="username">{{user.username || '未登录'}}</text>
        <text class="user-bio">{{user.bio || '这个人很懒，什么都没写~'}}</text>
      </view>
      <view wx:if="{{isLoggedIn}}" class="btn-edit" bindtap="editProfile">
        <text class="icon">✏️</text>
      </view>
    </view>
    
    <!-- 统计数据 -->
    <view class="user-stats">
      <view class="stat-item" bindtap="goToMyPosts">
        <text class="stat-value">{{stats.posts || 0}}</text>
        <text class="stat-label">帖子</text>
      </view>
      <view class="stat-item" bindtap="goToMyLikes">
        <text class="stat-value">{{stats.likes || 0}}</text>
        <text class="stat-label">获赞</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.following || 0}}</text>
        <text class="stat-label">关注</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.followers || 0}}</text>
        <text class="stat-label">粉丝</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <!-- 内容管理 -->
    <view class="menu-group">
      <text class="group-title">内容管理</text>
      <view class="menu-list">
        <view class="menu-item" bindtap="goToMyPosts">
          <view class="item-icon" style="background: #e3f2fd; color: #1976d2;">
            <text class="icon">📝</text>
          </view>
          <text class="item-title">我的帖子</text>
          <text class="arrow">›</text>
        </view>
        <view class="menu-item" bindtap="goToMyComments">
          <view class="item-icon" style="background: #f3e5f5; color: #7b1fa2;">
            <text class="icon">💬</text>
          </view>
          <text class="item-title">我的评论</text>
          <text class="arrow">›</text>
        </view>
        <view class="menu-item" bindtap="goToMyCollections">
          <view class="item-icon" style="background: #fff3e0; color: #f57c00;">
            <text class="icon">🔖</text>
          </view>
          <text class="item-title">我的收藏</text>
          <text class="arrow">›</text>
        </view>
        <view class="menu-item" bindtap="goToHistory">
          <view class="item-icon" style="background: #e8f5e9; color: #388e3c;">
            <text class="icon">🕐</text>
          </view>
          <text class="item-title">浏览历史</text>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 设置 -->
    <view class="menu-group">
      <text class="group-title">设置</text>
      <view class="menu-list">
        <view class="menu-item" bindtap="toggleTheme">
          <view class="item-icon" style="background: #fce4ec; color: #c2185b;">
            <text class="icon">{{isDarkMode ? '☀️' : '🌙'}}</text>
          </view>
          <text class="item-title">{{isDarkMode ? '浅色模式' : '深色模式'}}</text>
          <text class="arrow">›</text>
        </view>
        <view class="menu-item" bindtap="goToSettings">
          <view class="item-icon" style="background: #e0f2f1; color: #00796b;">
            <text class="icon">⚙️</text>
          </view>
          <text class="item-title">账号设置</text>
          <text class="arrow">›</text>
        </view>
        <view class="menu-item" bindtap="goToAbout">
          <view class="item-icon" style="background: #f5f5f5; color: #616161;">
            <text class="icon">ℹ️</text>
          </view>
          <text class="item-title">关于我们</text>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 登录/退出按钮 -->
  <view class="action-section">
    <button wx:if="{{!isLoggedIn}}" class="btn-primary" bindtap="goToLogin">
      登录 / 注册
    </button>
    <button wx:else class="btn-danger" bindtap="logout">
      退出登录
    </button>
  </view>
</view>
