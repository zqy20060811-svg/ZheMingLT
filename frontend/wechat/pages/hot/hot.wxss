.hot-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff5f5 0%, #fff 100%);
}

.dark-mode {
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
}

/* 时间筛选 */
.time-filter {
  display: flex;
  gap: 24rpx;
  padding: 32rpx;
  overflow-x: auto;
  background: rgba(255, 255, 255, 0.9);
}

.dark-mode .time-filter {
  background: rgba(30, 30, 46, 0.9);
}

.filter-btn {
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  background: #f0f2f5;
  color: #666;
  font-size: 28rpx;
  white-space: nowrap;
  transition: all 0.3s;
}

.filter-btn.active {
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  color: white;
}

.dark-mode .filter-btn {
  background: #2d2d44;
  color: #aaa;
}

/* 热门列表 */
.hot-list {
  padding: 0 32rpx;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx;
  color: #999;
}

.spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #e9ecef;
  border-top-color: #e74c3c;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.hot-item {
  display: flex;
  gap: 24rpx;
  padding: 32rpx;
  background: white;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.dark-mode .hot-item {
  background: #1e1e2e;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.2);
}

.rank-badge {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #e9ecef;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  font-size: 32rpx;
  flex-shrink: 0;
}

.rank-badge.top {
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  color: white;
}

.item-content {
  flex: 1;
  min-width: 0;
}

.item-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.dark-mode .item-title {
  color: #fff;
}

.item-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.item-stats {
  display: flex;
  gap: 24rpx;
  font-size: 24rpx;
  color: #999;
}

.item-stats .heat {
  color: #e74c3c;
  font-weight: 600;
}

.item-stats .icon {
  margin-right: 4rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  color: #999;
}

.empty-state .icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  display: block;
}
