<!-- index.wxml -->
<view class="container">
  <!-- 主题切换按钮 -->
  <view class="theme-toggle" bindtap="toggleTheme">
    <text class="theme-icon">{{theme === 'light' ? '🌙' : '☀️'}}</text>
  </view>
  
  <!-- 分类导航 -->
  <scroll-view scroll-x="true" class="category-scroll" style="white-space: nowrap; background-color: var(--card-background); padding: 16rpx 0; border-bottom: 2rpx solid var(--border-color);">
    <view class="category-item {{currentCategory === 0 ? 'active' : ''}} fade-in" bindtap="switchCategory" data-id="0">全部</view>
    <view wx:for="{{categories}}" wx:key="id" class="category-item {{currentCategory === item.id ? 'active' : ''}} fade-in" bindtap="switchCategory" data-id="{{item.id}}">{{item.name}}</view>
  </scroll-view>
  
  <!-- 帖子列表 -->
  <view wx:if="{{posts.length > 0}}">
    <view wx:for="{{posts}}" wx:key="id" class="card fade-in" bindtap="goToPostDetail" data-id="{{id}}">
      <!-- 帖子头部 -->
      <view class="post-header">
        <view class="post-author">
          <view class="author-avatar">
            <text>{{username ? username.charAt(0) : '?'}}</text>
          </view>
          <view class="author-info">
            <text class="author-name">{{username || '未知用户'}}</text>
            <text class="post-time">{{createdAt || '未知时间'}}</text>
          </view>
        </view>
        <view class="post-category">
          <text class="category-tag">{{categoryName || '未分类'}}</text>
        </view>
      </view>
      
      <!-- 帖子内容 -->
      <view class="post-title">{{title || '无标题'}}</view>
      <view class="post-summary">{{summary || '无内容'}}</view>
      
      <!-- 帖子图片 -->
      <view wx:if="{{imageUrl}}" class="post-image" style="margin: 15rpx 0; border-radius: 8rpx; overflow: hidden;">
        <image src="{{imageUrl}}" mode="aspectFill" style="width: 100%; height: 300rpx;" />
      </view>
      
      <!-- 帖子操作 -->
      <view class="post-actions">
        <view class="action-btn">
          <text class="icon">👁️</text>
          <text>{{viewCount || 0}}</text>
        </view>
        <view class="action-btn">
          <text class="icon">❤️</text>
          <text>{{likeCount || 0}}</text>
        </view>
        <view class="action-btn">
          <text class="icon">💬</text>
          <text>{{commentCount || 0}}</text>
        </view>
        <view class="action-btn">
          <text class="icon">↗️</text>
          <text>分享</text>
        </view>
      </view>
    </view>
    
    <!-- 加载更多 -->
    <view class="loading" wx:if="{{loading}}">
      <view class="spinner"></view>
    </view>
    <view class="empty" wx:else>
      <text>没有更多内容了</text>
    </view>
  </view>
  
  <!-- 空状态 -->
  <view class="empty" wx:else>
    <text class="empty-icon">📭</text>
    <text>暂无帖子</text>
    <text style="margin-top: 16rpx; font-size: 24rpx;">快来发布第一个帖子吧！</text>
  </view>
</view>