/* app.wxss */
/* 主题变量 */
:root {
  --primary-color: #4a6fa5;
  --secondary-color: #3a5a85;
  --background-color: #f8f9fa;
  --card-background: #ffffff;
  --text-color: #333333;
  --text-secondary: #666666;
  --border-color: #e9ecef;
  --shadow: 0 4rpx 6rpx rgba(0, 0, 0, 0.1);
  --shadow-lg: 0 10rpx 15rpx rgba(0, 0, 0, 0.1);
  --transition: all 0.3s ease;
  --border-radius: 12rpx;
  --border-radius-lg: 16rpx;
  --border-radius-sm: 8rpx;
}

/* 暗色主题 */
.dark-theme {
  --primary-color: #6b8cbe;
  --secondary-color: #4a6fa5;
  --background-color: #121212;
  --card-background: #1e1e1e;
  --text-color: #e0e0e0;
  --text-secondary: #b0b0b0;
  --border-color: #333333;
  --shadow: 0 4rpx 6rpx rgba(0, 0, 0, 0.3);
  --shadow-lg: 0 10rpx 15rpx rgba(0, 0, 0, 0.4);
}

page {
  background-color: var(--background-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  transition: var(--transition);
  overflow-x: hidden;
}

.container {
  padding: 16rpx;
  min-height: 100vh;
  position: relative;
}

/* 渐变背景 */
.gradient-bg {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
}

/* 帖子卡片 */
.card {
  background-color: var(--card-background);
  border-radius: var(--border-radius);
  box-shadow: var(--shadow);
  padding: 24rpx;
  margin-bottom: 20rpx;
  transition: var(--transition);
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4rpx;
  height: 100%;
  background: var(--primary-color);
  border-radius: var(--border-radius) 0 0 var(--border-radius);
}

.card:hover {
  transform: translateY(-5rpx);
  box-shadow: var(--shadow-lg);
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  color: white;
  border-radius: 30rpx;
  padding: 16rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  margin-top: 24rpx;
  transition: var(--transition);
  position: relative;
  overflow: hidden;
}

.btn-primary::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  transition: 0.5s;
}

.btn-primary:hover::before {
  left: 100%;
}

.btn-primary:hover {
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-lg);
}

.btn-secondary {
  background-color: var(--background-color);
  color: var(--text-color);
  border: 2rpx solid var(--border-color);
  border-radius: 30rpx;
  padding: 16rpx;
  text-align: center;
  font-size: 32rpx;
  margin-top: 16rpx;
  transition: var(--transition);
}

.btn-secondary:hover {
  background-color: var(--border-color);
  transform: translateY(-2rpx);
  border-color: var(--primary-color);
}

/* 输入框样式 */
.input-wrapper {
  position: relative;
  margin-bottom: 24rpx;
}

.input {
  border: 2rpx solid var(--border-color);
  border-radius: var(--border-radius);
  padding: 16rpx 50rpx 16rpx 16rpx;
  font-size: 32rpx;
  background-color: var(--card-background);
  color: var(--text-color);
  transition: var(--transition);
  width: 100%;
}

.input::placeholder {
  color: var(--text-secondary);
}

.input:focus {
  outline: none;
  border-color: var(--primary-color);
  box-shadow: 0 0 0 3rpx rgba(74, 111, 165, 0.1);
}

.input-icon {
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-secondary);
  font-size: 28rpx;
}

.textarea {
  border: 2rpx solid var(--border-color);
  border-radius: var(--border-radius);
  padding: 16rpx;
  font-size: 32rpx;
  margin-bottom: 16rpx;
  min-height: 200rpx;
  background-color: var(--card-background);
  color: var(--text-color);
  transition: var(--transition);
  width: 100%;
  resize: none;
}

.textarea::placeholder {
  color: var(--text-secondary);
}

.textarea:focus {
  outline: none;
  border-color: var(--primary-color);
  box-shadow: 0 0 0 3rpx rgba(74, 111, 165, 0.1);
}

/* 标题样式 */
.title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  color: var(--text-color);
  transition: var(--transition);
  text-align: center;
  position: relative;
  display: inline-block;
}

.title::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 4rpx;
  background: var(--primary-color);
  border-radius: 2rpx;
}

.subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 32rpx;
  text-align: center;
  transition: var(--transition);
}

.meta {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 16rpx;
  transition: var(--transition);
}

.divider {
  height: 8rpx;
  background-color: var(--border-color);
  margin: 24rpx 0;
  border-radius: 4rpx;
  transition: var(--transition);
}

/* 帖子样式 */
.post-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  color: var(--text-color);
  transition: var(--transition);
  line-height: 1.4;
}

.post-summary {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
  line-height: 1.6;
  transition: var(--transition);
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 帖子头部 */
.post-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.post-author {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.author-avatar {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  font-weight: 500;
  box-shadow: var(--shadow);
}

.author-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.author-name {
  font-weight: 500;
  color: var(--text-color);
  font-size: 26rpx;
  transition: var(--transition);
}

.post-time {
  font-size: 20rpx;
  color: var(--text-secondary);
  transition: var(--transition);
}

.post-category {
  display: flex;
  align-items: center;
}

.category-tag {
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  color: white;
  font-size: 20rpx;
  font-weight: 500;
  box-shadow: var(--shadow);
}

.post-meta {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 20rpx;
  transition: var(--transition);
}

.post-actions {
  display: flex;
  gap: 30rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid var(--border-color);
  transition: var(--transition);
}

.action-btn {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--text-secondary);
  transition: var(--transition);
  gap: 8rpx;
  padding: 8rpx 12rpx;
  border-radius: 20rpx;
  background-color: var(--background-color);
}

.action-btn:hover {
  color: var(--primary-color);
  background-color: rgba(74, 111, 165, 0.1);
  transform: translateY(-2rpx);
}

/* 评论样式 */
.comment-item {
  background-color: var(--background-color);
  border-radius: var(--border-radius);
  padding: 20rpx;
  margin-bottom: 16rpx;
  transition: var(--transition);
  border-left: 4rpx solid var(--primary-color);
}

.comment-author {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
  color: var(--text-color);
  transition: var(--transition);
}

.comment-content {
  font-size: 26rpx;
  color: var(--text-color);
  margin-bottom: 12rpx;
  line-height: 1.6;
  transition: var(--transition);
}

.comment-time {
  font-size: 22rpx;
  color: var(--text-secondary);
  transition: var(--transition);
}

.reply-item {
  background-color: var(--border-color);
  border-radius: var(--border-radius-sm);
  padding: 16rpx;
  margin-top: 16rpx;
  margin-left: 32rpx;
  transition: var(--transition);
  border-left: 4rpx solid var(--secondary-color);
}

/* 分类样式 */
.category-scroll {
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
}

.category-item {
  display: inline-block;
  padding: 10rpx 20rpx;
  margin-right: 16rpx;
  margin-bottom: 12rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  background-color: var(--background-color);
  color: var(--text-color);
  border: 2rpx solid var(--border-color);
  transition: var(--transition);
  font-weight: 500;
}

.category-item:hover {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  color: white;
  transform: translateY(-2rpx);
  border-color: transparent;
  box-shadow: var(--shadow);
}

.category-item.active {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  color: white;
  border-color: transparent;
  box-shadow: var(--shadow);
}

/* 加载动画 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 64rpx;
}

.spinner {
  width: 50rpx;
  height: 50rpx;
  border: 5rpx solid var(--border-color);
  border-top: 5rpx solid var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 128rpx 0;
  color: var(--text-secondary);
  font-size: 28rpx;
  transition: var(--transition);
  gap: 20rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

/* 表单样式 */
.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  margin-bottom: 12rpx;
  font-weight: 500;
  color: var(--text-color);
  font-size: 28rpx;
  transition: var(--transition);
}

/* 主题切换按钮 */
.theme-toggle {
  position: fixed;
  top: 20rpx;
  right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: var(--card-background);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow);
  transition: var(--transition);
  z-index: 999;
}

.theme-toggle:hover {
  transform: scale(1.1);
  box-shadow: var(--shadow-lg);
}

.theme-icon {
  font-size: 32rpx;
  transition: var(--transition);
}

/* 登录提示 */
.login-tip {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 32rpx;
  padding: 20rpx;
  background-color: var(--background-color);
  border-radius: var(--border-radius);
  border: 2rpx solid var(--border-color);
  transition: var(--transition);
}

/* 响应式设计 */
@media (max-width: 768rpx) {
  .post-title {
    font-size: 28rpx;
  }
  
  .card {
    padding: 20rpx;
  }
  
  .post-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 12rpx;
  }
  
  .post-actions {
    gap: 20rpx;
  }
  
  .action-btn {
    font-size: 22rpx;
  }
  
  .title {
    font-size: 36rpx;
  }
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateX(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.fade-in {
  animation: fadeIn 0.5s ease forwards;
}

.slide-in {
  animation: slideIn 0.5s ease forwards;
}

/* 滚动条样式 */
::-webkit-scrollbar {
  width: 6rpx;
}

::-webkit-scrollbar-track {
  background: var(--background-color);
}

::-webkit-scrollbar-thumb {
  background: var(--border-color);
  border-radius: 3rpx;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--primary-color);
}