.profile-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9fa 0%, #e9ecef 100%);
  padding-bottom: 60rpx;
}

.dark-mode {
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
}

/* 用户卡片 */
.user-card {
  position: relative;
  background: white;
  margin: 32rpx;
  border-radius: 40rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.08);
}

.dark-mode .user-card {
  background: #1e1e2e;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.2);
}

.card-bg {
  height: 200rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.user-info {
  display: flex;
  align-items: flex-start;
  padding: 0 40rpx 40rpx;
  margin-top: -80rpx;
  gap: 32rpx;
}

.user-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 8rpx solid white;
  background: #f0f2f5;
}

.dark-mode .user-avatar {
  border-color: #1e1e2e;
}

.user-details {
  flex: 1;
  padding-top: 80rpx;
}

.username {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.dark-mode .username {
  color: #fff;
}

.user-bio {
  font-size: 26rpx;
  color: #999;
  line-height: 1.4;
}

.btn-edit {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f0f2f5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 80rpx;
}

.dark-mode .btn-edit {
  background: #2d2d44;
}

.btn-edit .icon {
  font-size: 32rpx;
}

/* 统计数据 */
.user-stats {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 0;
  border-top: 2rpx solid #f0f2f5;
}

.dark-mode .user-stats {
  border-top-color: #2d2d44;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.dark-mode .stat-value {
  color: #fff;
}

.stat-label {
  font-size: 26rpx;
  color: #999;
}

/* 菜单区域 */
.menu-section {
  padding: 0 32rpx;
}

.menu-group {
  margin-bottom: 40rpx;
}

.group-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  display: block;
}

.menu-list {
  background: white;
  border-radius: 32rpx;
  overflow: hidden;
}

.dark-mode .menu-list {
  background: #1e1e2e;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 32rpx;
}

.menu-item:not(:last-child) {
  border-bottom: 2rpx solid #f5f5f5;
}

.dark-mode .menu-item:not(:last-child) {
  border-bottom-color: #2d2d44;
}

.item-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-icon .icon {
  font-size: 36rpx;
}

.item-title {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.dark-mode .item-title {
  color: #fff;
}

.arrow {
  color: #ccc;
  font-size: 32rpx;
}

/* 操作按钮 */
.action-section {
  padding: 0 32rpx;
}

.btn-primary, .btn-danger {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border: none;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.btn-danger {
  background: #ffebee;
  color: #e53935;
}
