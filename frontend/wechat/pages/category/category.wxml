<view class="category-page {{isDarkMode ? 'dark-mode' : ''}}">
  <!-- 分类网格 -->
  <view class="category-grid">
    <view
      wx:for="{{categories}}"
      wx:key="id"
      class="category-card"
      style="background: {{item.gradient}}"
      data-id="{{item.id}}"
      bindtap="goToCategoryDetail"
    >
      <view class="card-icon">
        <text class="icon">{{item.icon}}</text>
      </view>
      <view class="card-info">
        <text class="name">{{item.name}}</text>
        <text class="count">{{item.postCount || 0}} 帖子</text>
      </view>
    </view>
  </view>

  <!-- 推荐分类 -->
  <view class="recommend-section">
    <view class="section-title">
      <text class="icon">⭐</text>
      <text>推荐分类</text>
    </view>
    <view class="recommend-list">
      <view
        wx:for="{{recommendCategories}}"
        wx:key="id"
        class="recommend-item"
        data-id="{{item.id}}"
        bindtap="goToCategoryDetail"
      >
        <view class="item-icon" style="background-color: {{item.color}}">
          <text>{{item.icon}}</text>
        </view>
        <text class="item-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 全部分类 -->
  <view class="all-categories">
    <view class="section-title">
      <text class="icon">📋</text>
      <text>全部分类</text>
    </view>
    <view class="category-list">
      <view
        wx:for="{{allCategories}}"
        wx:key="id"
        class="list-item"
        data-id="{{item.id}}"
        bindtap="goToCategoryDetail"
      >
        <view class="item-left">
          <view class="item-icon-small" style="background-color: {{item.color}}">
            <text>{{item.icon}}</text>
          </view>
          <view class="item-info">
            <text class="item-title">{{item.name}}</text>
            <text class="item-desc">{{item.description || '暂无描述'}}</text>
          </view>
        </view>
        <view class="item-right">
          <text class="post-count">{{item.postCount || 0}} 帖</text>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>
  </view>
</view>
