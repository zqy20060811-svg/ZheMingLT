<!-- post-detail.wxml -->
<view class="container">
  <view class="card">
    <view class="post-title">{{post.title}}</view>
    <view class="post-meta">
      <text>{{post.username}}</text>
      <text style="margin: 0 12rpx;">|</text>
      <text>{{post.categoryName}}</text>
      <text style="margin: 0 12rpx;">|</text>
      <text>{{post.createdAt}}</text>
      <text style="margin: 0 12rpx;">|</text>
      <text>浏览 {{post.viewCount}}</text>
    </view>
    <view class="divider"></view>
    <view class="post-content" style="font-size: 28rpx; line-height: 1.8; color: #333;">{{post.content}}</view>
    
    <!-- 帖子操作 -->
    <view class="post-actions">
      <view class="action-btn" bindtap="likePost">
        <text class="icon">{{isLiked ? '❤️' : '🤍'}}</text>
        <text>{{post.likeCount}}</text>
      </view>
      <view class="action-btn">
        <text class="icon">🔗</text>
        <text>分享</text>
      </view>
      <view class="action-btn" bindtap="collectPost">
        <text class="icon">{{isCollected ? '⭐' : '☆'}}</text>
        <text>收藏</text>
      </view>
    </view>
  </view>
  
  <!-- 评论区 -->
  <view class="card" style="margin-top: 16rpx;">
    <view class="title" style="margin-bottom: 16rpx;">评论 ({{post.commentCount}})</view>
    
    <!-- 评论表单 -->
    <view class="form-group">
      <textarea class="textarea" placeholder="写下你的评论..." value="{{commentContent}}" bindinput="inputChange" data-field="commentContent"></textarea>
      <button class="btn-primary" bindtap="submitComment" style="margin-top: 8rpx;">发布评论</button>
    </view>
    
    <!-- 评论列表 -->
    <view wx:if="{{comments.length > 0}}">
      <view wx:for="{{comments}}" wx:key="id" class="comment-item">
        <view class="comment-author">{{item.username}}</view>
        <view class="comment-time">{{item.createdAt}}</view>
        <view class="comment-content">{{item.content}}</view>
        <view class="action-btn" style="margin-top: 8rpx;" bindtap="showReplyForm" data-id="{{item.id}}">
          <text>回复</text>
        </view>
        
        <!-- 回复表单 -->
        <view wx:if="{{replyTo === item.id}}" class="reply-form" style="margin-top: 16rpx; padding-top: 16rpx; border-top: 2rpx solid #f0f0f0;">
          <textarea class="textarea" placeholder="写下你的回复..." value="{{replyContent}}" bindinput="inputChange" data-field="replyContent"></textarea>
          <view style="display: flex; justify-content: flex-end; margin-top: 8rpx;">
            <button class="btn-primary" style="width: 200rpx; font-size: 28rpx; padding: 12rpx;" bindtap="submitReply" data-id="{{item.id}}">回复</button>
          </view>
        </view>
        
        <!-- 回复列表 -->
        <view wx:if="{{item.replies && item.replies.length > 0}}">
          <view wx:for="{{item.replies}}" wx:key="id" class="reply-item">
            <view class="comment-author">{{item.username}}</view>
            <view class="comment-time">{{item.createdAt}}</view>
            <view class="comment-content">{{item.content}}</view>
          </view>
        </view>
      </view>
    </view>
    <view wx:else class="empty">
      <text>暂无评论</text>
    </view>
  </view>
</view>